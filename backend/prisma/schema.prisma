generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Damper {
  id                    Int      @id @default(autoincrement())
  imalatNo              Int?
  musteri               String
  aracGeldiMi           Boolean  @default(false)
  aracMarka             String?
  model                 String?
  tip                   String
  malzemeCinsi          String
  m3                    String?
  renk                  String?
  plazmaProgrami        Boolean  @default(false)
  sacMalzemeKontrolu    Boolean  @default(false)
  plazmaKesim           Boolean  @default(false)
  damperSasiPlazmaKesim Boolean  @default(false)
  presBukum             Boolean  @default(false)
  aracBraket            Boolean  @default(false)
  damperSasi            Boolean  @default(false)
  sasiYukleme           Boolean  @default(false)
  milAltKutuk           Boolean  @default(false)
  taban                 Boolean  @default(false)
  yan                   Boolean  @default(false)
  onGogus               Boolean  @default(false)
  arkaKapak             Boolean  @default(false)
  yuklemeMalzemesi      Boolean  @default(false)
  damperKurulmasi       Boolean  @default(false)
  damperKaynak          Boolean  @default(false)
  sasiKapakSiperlik     Boolean  @default(false)
  yukleme               Boolean  @default(false)
  hidrolik              Boolean  @default(false)
  boyaHazirlik          Boolean  @default(false)
  boya                  Boolean  @default(false)
  elektrik              Boolean  @default(false)
  hava                  Boolean  @default(false)
  tamamlama             Boolean  @default(false)
  sonKontrol            Boolean  @default(false)
  kurumMuayenesi        String   @default("YOK")
  dmoMuayenesi          String   @default("MUAYENE YOK")
  teslimat              Boolean  @default(false)
  teslimSasiNo          String?
  teslimEden            String?
  teslimAlan            String?
  teslimAlanFirma       String?
  teslimNot             String?  @db.Text
  teslimAt              DateTime?
  branda                Boolean  @default(false)
  brandaMontaji         Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  adet                  Int      @default(1)
  sasiNo                String?
  productionStartedAt   DateTime?
  cardNote              String?  @db.Text
}

model Dorse {
  id                    Int      @id @default(autoincrement())
  imalatNo              Int?
  musteri               String
  cekiciGeldiMi         Boolean  @default(false)
  dingil                String?
  lastik                String?
  tampon                String?
  kalinlik              String?
  m3                    String?
  renk                  String?
  
  // KESIM - BUKUM
  plazmaProgrami        Boolean  @default(false)
  sacMalzemeKontrolu    Boolean  @default(false)
  plazmaKesim           Boolean  @default(false)
  presBukum             Boolean  @default(false)
  dorseSasi             Boolean  @default(false)

  // ON HAZIRLIK
  milAltKutuk           Boolean  @default(false)
  taban                 Boolean  @default(false)
  yan                   Boolean  @default(false)
  onGogus               Boolean  @default(false)
  arkaKapak             Boolean  @default(false)
  yuklemeMalzemesi      Boolean  @default(false)

  // MONTAJ
  dorseKurulmasi        Boolean  @default(false)
  dorseKaynak           Boolean  @default(false)
  kapakSiperlik         Boolean  @default(false)
  yukleme               Boolean  @default(false)
  hidrolik              Boolean  @default(false)

  // BOYA
  boyaHazirlik          Boolean  @default(false)
  dorseSasiBoyama       Boolean  @default(false)

  // TAMAMLAMA
  frenProgrami          Boolean  @default(false)
  fren                  Boolean  @default(false)
  dorseElektrik         Boolean  @default(false)
  tamamlama             Boolean  @default(false)
  cekiciElektrik        Boolean  @default(false)
  cekiciHidrolik        Boolean  @default(false)
  aracKontrolBypassAyari Boolean @default(false)
  
  // SON KONTROL
  sonKontrol            Boolean  @default(false)
  tipOnay               Boolean  @default(false)
  fatura                Boolean  @default(false)
  akmTseMuayenesi       String   @default("YOK")
  dmoMuayenesi          String   @default("MUAYENE YOK")
  tahsilat              Boolean  @default(false)
  teslimat              Boolean  @default(false)
  teslimSasiNo          String?
  teslimEden            String?
  teslimAlan            String?
  teslimAracSahibi      String?
  teslimNot             String?  @db.Text
  teslimAt              DateTime?
  branda                Boolean  @default(false)
  brandaMontaji         Boolean  @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  adet                  Int      @default(1)
  sasiNo                String?
  silindir              String?
  malzemeCinsi          String?
  frenMarka             String?
  productionStartedAt   DateTime?
  cardNote              String?  @db.Text

  // RELATIONSHIP
  sasiId                Int?     @unique
  sasi                  Sasi?    @relation(fields: [sasiId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  fullName  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  loginLogs LoginLog[]
  auditLogs AuditLog[]
  notificationReads     NotificationRead[]
  authoredNotifications Notification[]     @relation("NotificationActor")
  stockMovements        StockMovement[]
  stockSupplierChanges  StockSupplierHistory[]
  completedMaintenanceSchedules MaintenanceSchedule[] @relation("MaintenanceCompletedBy")
  handledCompanyReminders       Company[]             @relation("CompanyReminderHandledBy")
}

/// Yeni ürün / sistem bildirimleri; satırlar uygulama tarafından silinmez (arşiv).
model Notification {
  id          Int      @id @default(autoincrement())
  kind        String   @default("NEW_PRODUCT")
  productType String
  productId   Int
  title       String
  body        String?  @db.Text
  actorUserId Int?
  actor       User?    @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  reads       NotificationRead[]

  @@index([createdAt])
  @@index([productType, productId])
}

model NotificationRead {
  id             Int      @id @default(autoincrement())
  userId         Int
  notificationId Int
  readAt         DateTime @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
}

/// Ürün güncellemelerinde kimin neyi değiştirdiği (ek kayıt; ürün satırları silinmez).
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username    String?
  action      String
  productType String
  productId   Int
  summary     String?
  details     Json?
  createdAt   DateTime @default(now())

  @@index([productType, productId])
  @@index([createdAt])
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  loginAt   DateTime @default(now())
  ipAddress String?
}

model Sasi {
  id                    Int      @id @default(autoincrement())
  imalatNo              Int?
  musteri               String?
  sasiNo                String?
  tampon                String?
  dingil                String?
  
  // KESIM - BUKUM
  plazmaProgrami        Boolean  @default(false)
  sacMalzemeKontrolu    Boolean  @default(false)
  plazmaKesim           Boolean  @default(false)
  presBukum             Boolean  @default(false)

  // ON HAZIRLIK
  lenjorenMontaji       Boolean  @default(false)
  robotKaynagi          Boolean  @default(false)

  // MONTAJ
  saseFiksturCatim      Boolean  @default(false)
  kaynak                Boolean  @default(false)
  dingilMontaji         Boolean  @default(false)
  genelKaynak           Boolean  @default(false)
  tesisatCubugu         Boolean  @default(false)
  mekanikAyak           Boolean  @default(false)
  korukMontaji          Boolean  @default(false)
  lastikMontaji         Boolean  @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  adet                  Int      @default(1)
  productionStartedAt   DateTime?
  cardNote              String?  @db.Text

  // RELATIONSHIP
  dorse                 Dorse?
}

model StepCompletionEvent {
  id           Int      @id @default(autoincrement())
  productType  String
  productId    Int
  mainStepKey  String
  completedAt  DateTime @default(now())

  @@index([productType, productId, mainStepKey])
  @@index([productType, completedAt])
}

/// Ürün kartındaki adım / alt-adım toggle değişiklikleri (silinmez; ileri analiz için ham log).
model StepToggleEvent {
  id          Int      @id @default(autoincrement())
  userId      Int?
  username    String?
  productType String
  productId   Int
  fieldKey    String
  fromValue   Boolean?
  toValue     Boolean?
  createdAt   DateTime @default(now())

  @@index([productType, productId])
  @@index([fieldKey])
  @@index([createdAt])
}

/// Haftalık bölüm kapasitesi (Pazartesi hafta başı). normalHours = bölüm toplam kişi-saat (genelde kişi × 45).
model DepartmentWeekCapacity {
  id              Int      @id @default(autoincrement())
  productType     String
  mainStepKey     String
  weekStart       DateTime @db.Date
  headcount       Int      @default(0)
  normalHours     Float    @default(0)
  overtimeHours   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productType, mainStepKey, weekStart])
  @@index([productType, weekStart])
}

/// Haftalık bölüm hedef adedi (verimlilik raporunda hedef / sapma için).
model WeeklyStepTarget {
  id           Int      @id @default(autoincrement())
  productType  String
  mainStepKey  String
  weekStart    DateTime @db.Date
  targetCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([productType, mainStepKey, weekStart])
  @@index([productType, weekStart])
}

/// Teklif Takip → tek satır / teslimat: aynı sourceDeliveryId = tek kart (inbound + delivered güncellemesi).
model VehicleDeliveryEvent {
  id                    Int       @id @default(autoincrement())
  sourceDeliveryId      String    @unique @map("source_delivery_id")
  companyName           String    @map("company_name")
  payloadJson           Json?     @map("payload_json")
  deliveredPayloadJson  Json?     @map("delivered_payload_json")
  arrivedAt             DateTime? @map("arrived_at")
  deliveredAt           DateTime? @map("delivered_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([companyName])
  @@index([createdAt])
  @@map("vehicle_delivery_event")
}

/// Teklif Takip → İmalat Takip: onaylı teklif özeti (Damper/Dorse satırlarına dokunmaz).
model ProposalIngest {
  id                 Int       @id @default(autoincrement())
  sourceProposalId   String    @unique @map("source_proposal_id")
  companyName        String    @map("company_name")
  proposalDate       DateTime  @map("proposal_date")
  quantity           Float
  equipment          String?
  vehicle            String?
  volume             String?
  thickness          String?
  deliveryDate       DateTime? @map("delivery_date")
  contactPerson      String?   @map("contact_person")
  notes              String?   @db.Text
  ownerEmail         String?   @map("owner_email")
  pushedAt           DateTime  @map("pushed_at")
  pushedBy           String?   @map("pushed_by")
  approvalLoggedAt       DateTime? @map("approval_logged_at")
  imalataAlindi          Boolean   @default(false) @map("imalata_alindi")
  teknikPdfUrl           String?   @map("teknik_pdf_url")
  /// Teklif Takip: teknik şartname PDF (public URL); opsiyonel.
  teknikSartnamePdfUrl   String?   @map("teknik_sartname_pdf_url")
  /// Teklif Takip: ek PDF (public URL); opsiyonel.
  ekPdfUrl               String?   @map("ek_pdf_url")
  manufacturingNot       String?   @map("manufacturing_not") @db.Text
  manufacturingAciliyet  String?   @map("manufacturing_aciliyet")
  /// Planlama ekranı: DAMPER | DORSE (bölüm şablonu).
  planningProductType    String?   @map("planning_product_type")
  expectedDeliveryDays     Int?      @map("expected_delivery_days")
  targetDeliveryDate       DateTime? @map("target_delivery_date")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  planSegments ProposalPlanSegment[]

  @@index([pushedAt])
  @@index([imalataAlindi])
  @@index([approvalLoggedAt])
  @@map("proposal_ingest")
}

/// Onaylı teklif bazlı üretim planı (ana bölüm tarihleri). unitIndex = araç sırası (1..miktar).
model ProposalPlanSegment {
  id                 Int       @id @default(autoincrement())
  proposalIngestId   Int       @map("proposal_ingest_id")
  proposalIngest     ProposalIngest @relation(fields: [proposalIngestId], references: [id], onDelete: Cascade)
  unitIndex          Int       @default(1) @map("unit_index")
  mainStepKey        String    @map("main_step_key")
  plannedStart       DateTime  @map("planned_start")
  plannedEnd         DateTime  @map("planned_end")
  durationDays       Int?      @map("duration_days")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([proposalIngestId, unitIndex, mainStepKey])
  @@index([proposalIngestId])
  @@map("proposal_plan_segment")
}

/// Stok grupları (Excel GRUP sütunu vb.).
model StockGroup {
  id        Int @id @default(autoincrement())
  name      String      @unique
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     StockItem[]
}

/// Stok kalemi (satınalma kodu, tanım, birim, miktar, tedarikçi).
model StockItem {
  id              Int                     @id @default(autoincrement())
  groupId         Int
  group           StockGroup              @relation(fields: [groupId], references: [id], onDelete: Restrict)
  purchaseCode    String?
  description     String
  unit            String?
  quantity        Decimal?                @db.Decimal(18, 4)
  /// Kritik stok eşiği; miktar buna inince/altına düşünce bildirim üretilir
  criticalQuantity Decimal?               @db.Decimal(18, 4)
  supplierName    String?
  supplierContact String?                 @db.Text
  /// Bu ürün için mevcut tedarikçideki ödeme vadesi (örn. 30 gün)
  supplierPaymentTerm String?
  /// Bu ürün için mevcut tedarikçideki termin süresi (örn. 15 gün)
  supplierLeadTime    String?
  /// Ana kalem: sayfa açılışında öncelikli listelenir
  isMainItem      Boolean                 @default(false)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  priceHistory    StockUnitPriceHistory[]
  movements       StockMovement[]
  supplierHistory StockSupplierHistory[]
  documents       StockItemDocument[]

  @@unique([groupId, purchaseCode])
  @@index([groupId])
  @@index([description])
  @@index([isMainItem])
}

/// Ürün / teknik resim geçmişi (tedarikçi değişince yenisi eklenir, eskiler kalır).
model StockItemDocument {
  id                 Int       @id @default(autoincrement())
  stockItemId        Int
  stockItem          StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  /// PRODUCT_IMAGE | TECH_DRAWING
  kind               String    @default("PRODUCT_IMAGE")
  mimeType           String
  data               Bytes
  sizeBytes          Int
  originalFileName   String?
  note               String?
  /// Yükleme anındaki tedarikçi anlık görüntüsü
  supplierName       String?
  supplierContact    String?   @db.Text
  uploadedByUsername String?
  createdAt          DateTime  @default(now())

  @@index([stockItemId, createdAt])
}

/// Birim fiyat geçmişi (satın alma / güncelleme).
model StockUnitPriceHistory {
  id          Int       @id @default(autoincrement())
  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  recordedAt  DateTime  @default(now())
  unitPrice   Decimal   @db.Decimal(18, 4)
  /// TRY | USD | EUR
  currency    String    @default("TRY")
  note        String?
  /// Kayıt anındaki tedarikçi (kalem üzerindeki değerin kopyası).
  supplierName    String?
  supplierContact String? @db.Text

  @@index([stockItemId, recordedAt])
}

/// Stok hareketleri: her kalem için giriş (IN) ve çıkış (OUT) kayıtları.
model StockMovement {
  id          Int       @id @default(autoincrement())
  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  type        String    // 'IN' | 'OUT'
  quantity    Decimal   @db.Decimal(18, 4)
  /// Hareket sonrası kalan stok (audit için — anlık snapshot).
  balanceAfter Decimal? @db.Decimal(18, 4)
  note        String?
  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  recordedAt  DateTime  @default(now())

  @@index([stockItemId, recordedAt])
  @@index([type])
}

/// Tedarikçi değişiklik geçmişi (kimin ne zaman ne değiştirdiği).
model StockSupplierHistory {
  id              Int       @id @default(autoincrement())
  stockItemId     Int
  stockItem       StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  prevSupplierName    String?
  prevSupplierContact String?   @db.Text
  prevSupplierPaymentTerm String?
  prevSupplierLeadTime String?
  supplierName    String?
  supplierContact String?   @db.Text
  supplierPaymentTerm String?
  supplierLeadTime String?
  note            String?
  userId          Int?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  recordedAt      DateTime  @default(now())

  @@index([stockItemId, recordedAt])
}

model VehicleDamageRecord {
  id                       Int       @id @default(autoincrement())
  sasiNo                   String
  status                   String    @default("KAYDI_GIRILDI")
  responsiblesJson         Json
  processOwner             String?
  requiresPart             Boolean   @default(false)
  partCost                 Decimal?  @db.Decimal(14, 2)
  laborCost                Decimal?  @db.Decimal(14, 2)
  repairLocation           String?
  serviceDirection         String?
  cost                     Decimal?  @db.Decimal(14, 2)
  notes                    String?   @db.Text
  isCompleted              Boolean   @default(false)
  createdByUsername        String?
  processStartedAt         DateTime?
  processStartedByUsername String?
  completedAt              DateTime?
  completedByUsername      String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  photos                   VehicleDamagePhoto[]

  @@index([sasiNo])
  @@index([status])
  @@index([createdAt])
}

model VehicleDamagePhoto {
  id                 Int                 @id @default(autoincrement())
  vehicleDamageId    Int
  vehicleDamage      VehicleDamageRecord @relation(fields: [vehicleDamageId], references: [id], onDelete: Cascade)
  mimeType           String
  data               Bytes
  sizeBytes          Int
  originalFileName   String?
  displayOrder       Int                 @default(0)
  createdAt          DateTime            @default(now())

  @@index([vehicleDamageId, displayOrder])
}

model SshTalepNoSequence {
  year       Int @id
  lastNumber Int @default(0)
}

model SshComplaint {
  id                      Int       @id @default(autoincrement())
  talepNo                 String    @unique
  talepTipi               String
  sikayetBildirimTarihi   DateTime
  garantiBaslangicTarihi  DateTime
  musteriAdi              String
  ilgiliKisi             String?
  ilgiliKisiTel          String?
  ustYapiTipi            String
  sasiMarka              String?
  sasiModel              String?
  aracPlakasi            String?
  sasiNo                 String?
  imalatNo               String?
  arizaBolge1            String?
  arizaBolge2            String?
  arizaBolge3            String?
  arizaTipi              String?
  arizaKodu              String?
  hataKaynagi            String?
  tedarikciAdi           String?
  arizaAciklamasi        String?   @db.Text
  tekrarEdenHataSayisi   Int       @default(1)
  aracCikisSuresiGun     Int?
  cikisSureKatsayisi     Int?
  oncelikPrio            String?
  oncelikKatsayisi       Int?
  etkiAdi                String?
  etkiKatsayisi          Int?
  analizPuani            Int?
  kritikPuan             Int?
  fabrikaGarantiKarari   String?
  garantiTipi            String?
  maliyetDetay           Json?
  toplamTutar            Decimal?  @db.Decimal(14, 2)
  onaylananTutar         Decimal?  @db.Decimal(14, 2)
  faturaTarihi           DateTime?
  onarim                 String?   @db.Text
  onarimTarihi           DateTime?
  kokNeden               String?   @db.Text
  kaliciOnlem            String?   @db.Text
  kaliciOnlemTarihi      DateTime?
  /// 8D D6 – Uygulanan kalıcı düzeltici aksiyon(lar)
  d6UygulananAksiyon     String?   @db.Text
  /// 8D D7 – Şikayet kapanış / önleyici aksiyon özeti
  d7SikayetKapanis       String?   @db.Text
  status                 String    @default("AÇIK")
  createdByUsername      String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  photos                 SshComplaintPhoto[]

  @@index([status])
  @@index([kritikPuan])
  @@index([createdAt])
  @@index([musteriAdi])
  @@index([aracPlakasi])
}

model SshComplaintPhoto {
  id               Int           @id @default(autoincrement())
  sshComplaintId   Int
  sshComplaint     SshComplaint  @relation(fields: [sshComplaintId], references: [id], onDelete: Cascade)
  mimeType         String
  data             Bytes
  sizeBytes        Int
  originalFileName String?
  displayOrder     Int           @default(0)
  createdAt        DateTime      @default(now())

  @@index([sshComplaintId, displayOrder])
}

/// Firma rehberi (bakım modülü): teslim edilen ürünlerdeki musteri alanından normalize edilerek oluşur.
model Company {
  id            Int      @id @default(autoincrement())
  normalizedKey String   @unique
  displayName   String
  email         String?
  phone         String?
  phone2        String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Firma bazlı bakım hatırlatma takibi (tamamlanma değil; insan eylemi durumu)
  // PENDING -> ACKNOWLEDGED -> CONTACTED -> SERVICED
  reminderStatus          String    @default("PENDING")
  reminderNote            String?   @db.Text
  reminderHandledAt       DateTime?
  reminderHandledByUserId Int?
  reminderHandledByUser   User?     @relation("CompanyReminderHandledBy", fields: [reminderHandledByUserId], references: [id], onDelete: SetNull)

  maintenanceSchedules MaintenanceSchedule[]

  @@index([displayName])
  @@index([reminderStatus])
}

/// Teslim edilen her damper/dorse için tek bakım planı (unique productType+productId).
model MaintenanceSchedule {
  id                Int      @id @default(autoincrement())
  productType        String
  productId          Int
  companyId          Int
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  deliveredAt        DateTime
  dueAt              DateTime
  intervalDays       Int      @default(365)
  status             String   @default("SCHEDULED")

  completedAt        DateTime?
  completedByUserId  Int?
  completedByUser    User?    @relation("MaintenanceCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  completionNote     String?  @db.Text

  lastNotifiedAt     DateTime?
  snoozedUntil       DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([productType, productId])
  @@index([companyId])
  @@index([dueAt])
  @@index([status])
  @@index([productType, dueAt])
}

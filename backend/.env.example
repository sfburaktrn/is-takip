# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations and npm run db:sync
# (Pooler 6543 ile db push güvenilir olmayabilir; şema senkronu için DIRECT_URL şart.)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

PORT=3001

# Teklif Takip → İmalat Takip sunucu-sunucu ingest (Authorization: Bearer …)
IMALAT_INGEST_SECRET=""

# Session secret key for authentication
SESSION_SECRET="your-super-secret-key-change-this-in-production"

# İsteğe bağlı: Verimlilik sayfası AI özeti (admin)
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
